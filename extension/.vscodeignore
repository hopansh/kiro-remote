# Development files — excluded from the packaged VSIX
.vscode/**
.vscode-test/**
src/**
.gitignore
tsconfig.json
**/*.ts
**/*.map

# Compiled extension JS — included
!out/**

# Hook scripts bundled into the extension — included
!hooks/**

# Bundled assets (generated by npm run build)
# relay-server/dist is copied here by scripts/sync-bundle.js
!server/**

# Bundled assets (generated by npm run build)
# mobile-ui/ source is copied here by scripts/sync-bundle.js
!mobile-ui/**

# Extension assets — included
!icon.png
!icon.svg
!README.md
!LICENSE
