{
  "name": "kiro-remote-control",
  "displayName": "Kiro Remote Control",
  "description": "Control your Kiro IDE from your Android phone — view chat, approve tool calls, and send messages remotely.",
  "version": "0.1.2",
  "publisher": "kiro-remote-control",
  "icon": "icon.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["kiro", "remote", "mobile", "android", "pwa"],
  "repository": {
    "type": "git",
    "url": "https://github.com/hopansh/kiro-remote-control.git"
  },
  "homepage": "https://github.com/hopansh/kiro-remote-control#readme",
  "bugs": {
    "url": "https://github.com/hopansh/kiro-remote-control/issues"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kiroRemote.start",
        "title": "Start Remote Session",
        "category": "Kiro Remote"
      },
      {
        "command": "kiroRemote.stop",
        "title": "Stop Remote Session",
        "category": "Kiro Remote"
      },
      {
        "command": "kiroRemote.showQR",
        "title": "Show QR Code",
        "category": "Kiro Remote"
      },
      {
        "command": "kiroRemote.installHooks",
        "title": "Install Hooks into Workspace",
        "category": "Kiro Remote"
      },
      {
        "command": "kiroRemote.showLogs",
        "title": "Show Logs",
        "category": "Kiro Remote"
      },
      {
        "command": "kiroRemote.resetToken",
        "title": "Reset Session Token",
        "category": "Kiro Remote"
      }
    ],
    "configuration": {
      "title": "Kiro Remote Control",
      "properties": {
        "kiroRemote.relayPort": {
          "type": "number",
          "default": 3737,
          "description": "Port for the local relay server"
        },
        "kiroRemote.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start relay server when Kiro opens"
        },
        "kiroRemote.approvalTimeoutSeconds": {
          "type": "number",
          "default": 60,
          "description": "Seconds to wait for phone approval before auto-denying"
        },
        "kiroRemote.sessionTimeoutMinutes": {
          "type": "number",
          "default": 240,
          "description": "Minutes a remote session stays valid before the QR/token expires"
        },
        "kiroRemote.preventSleep": {
          "type": "boolean",
          "default": true,
          "description": "Keep your Mac awake (via 'caffeinate') while a remote session is active, so the relay stays reachable from your phone"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run compile && node scripts/sync-bundle.js",
    "package": "npm run build && vsce package --allow-missing-repository --skip-license --no-dependencies",
    "package:only": "vsce package --allow-missing-repository --skip-license --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {}
}
